  taxAmount      Decimal           @default(0) @db.Decimal(14, 2)
  totalAmount    Decimal           @default(0) @db.Decimal(14, 2)
  outstandingAmount Decimal        @default(0) @db.Decimal(14, 2)
  status         SupplierBillStatus @default(DRAFT)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplier Vendor @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  subcontract Subcontract? @relation(fields: [subcontractId], references: [id], onDelete: SetNull)
  lines SupplierBillLine[]

  @@index([projectId])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([subcontractId])
  @@index([status])
  @@index([billDate])
  @@index([dueDate])
}

model SupplierBillLine {
  id           String   @id @default(cuid())
  supplierBillId String
  itemId       String?
  description  String
  quantity     Decimal  @default(0) @db.Decimal(14, 2)
  unitCost     Decimal  @default(0) @db.Decimal(14, 2)
  lineAmount   Decimal  @default(0) @db.Decimal(14, 2)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplierBill SupplierBill @relation(fields: [supplierBillId], references: [id], onDelete: Cascade)
  item         ItemMaster?  @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([supplierBillId])
  @@index([itemId])
  @@index([sortOrder])
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  itemId      String?
  sku         String?
  description String
  unit        String   @default("lot")
  quantity    Decimal  @default(1) @db.Decimal(14, 2)
  unitPrice   Decimal  @default(0) @db.Decimal(14, 2) @map("unitRate")
  lineAmount  Decimal  @default(0) @db.Decimal(14, 2) @map("amount")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item    ItemMaster? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([itemId])
  @@index([sortOrder])

  @@map("InvoiceLineItem")
}

model PaymentSchedule {
  id          String              @id @default(cuid())
  projectId   String
  contractId  String?
  quotationId String?
  invoiceId   String?

  label       String             @map("title")
  scheduleType PaymentScheduleType @default(MANUAL)
  dueDate     DateTime?
  percentage  Decimal?           @db.Decimal(7, 4) @map("percent")
  scheduledAmount Decimal        @default(0) @db.Decimal(14, 2) @map("amount")
  billedAmount Decimal           @default(0) @db.Decimal(14, 2)
  paidAmount  Decimal            @default(0) @db.Decimal(14, 2)
  status      PaymentScheduleStatus @default(PENDING)
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contract  Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  quotation Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  allocations PaymentScheduleInvoice[]

  @@index([projectId])
  @@index([contractId])
  @@index([quotationId])
  @@index([invoiceId])
  @@index([dueDate])
  @@index([status])
  @@index([sortOrder])

  @@map("PaymentScheduleItem")
}

model PaymentScheduleInvoice {
  id               String   @id @default(cuid())
  paymentScheduleId String
  invoiceId        String
  allocatedSubtotal Decimal @default(0) @db.Decimal(14, 2)
  createdAt        DateTime @default(now())

  paymentSchedule PaymentSchedule @relation(fields: [paymentScheduleId], references: [id], onDelete: Cascade)
  invoice         Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([paymentScheduleId, invoiceId])
  @@index([paymentScheduleId])
  @@index([invoiceId])
}

model PaymentReceipt {
  id            String   @id @default(cuid())
  projectId     String
  invoiceId     String?
  receiptNumber String   @unique
  paymentDate   DateTime @default(now()) @map("receivedAt")
  amount        Decimal  @default(0) @db.Decimal(14, 2)
  paymentMethod String?  @map("method")
  referenceNo   String?  @map("reference")
  notes         String?
  xeroPaymentId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([invoiceId])
  @@index([paymentDate])

  @@map("InvoicePayment")
}

model CreditNote {
  id               String           @id @default(cuid())
  projectId        String
  invoiceId        String?
  creditNoteNumber String           @unique
  issueDate        DateTime
  amount           Decimal          @default(0) @db.Decimal(14, 2)
  reason           String
  status           CreditNoteStatus @default(DRAFT)
  xeroCreditNoteId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([invoiceId])
  @@index([issueDate])
  @@index([status])
}

model QuotationSection {
  id          String        @id @default(cuid())
  quotationId String
  category    ScopeCategory
  title       String
  description String?
  isIncluded  Boolean       @default(true)
  isOptional  Boolean       @default(false)
  remarks     String?
  sortOrder   Int           @default(0)
  subtotal    Decimal       @default(0) @db.Decimal(14, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  quotation Quotation           @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  lineItems QuotationItem[]

  @@index([quotationId])
  @@index([category])
  @@index([sortOrder])
}

model QuotationItem {
  id                 String       @id @default(cuid())
  quotationSectionId String       @map("quotationSectionId")
  itemType           LineItemType @default(SUPPLY_AND_INSTALL)
  sku                String       @default("")
  itemMasterId       String?
  description        String
  specification      String?
  unit               String
  unitOfMeasureId    String?
  quantity           Decimal      @default(0) @db.Decimal(14, 2)
  unitPrice          Decimal      @default(0) @db.Decimal(14, 2) @map("unitRate")
  costPrice          Decimal      @default(0) @db.Decimal(14, 2)
  totalPrice         Decimal      @default(0) @db.Decimal(14, 2) @map("amount")
  totalCost          Decimal      @default(0) @db.Decimal(14, 2)
  profit             Decimal      @default(0) @db.Decimal(14, 2)
  marginPercent      Decimal      @default(0) @db.Decimal(7, 4)
  remarks            String?
  isIncluded         Boolean      @default(true)
  isOptional         Boolean      @default(false)
  sortOrder          Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  quotationSection QuotationSection @relation(fields: [quotationSectionId], references: [id], onDelete: Cascade)
  itemMaster       ItemMaster? @relation(fields: [itemMasterId], references: [id], onDelete: SetNull)
  unitOfMeasure    UnitOfMeasure? @relation(fields: [unitOfMeasureId], references: [id], onDelete: SetNull)
  cost             QuotationLineItemCost?
  qsDraftItems     QSBoqDraftItem[]

  @@map("QuotationLineItem")
  @@index([quotationSectionId])
  @@index([itemMasterId])
  @@index([unitOfMeasureId])
  @@index([sortOrder])
}

model QuotationLineItemCost {
  id         String   @id @default(cuid())
  lineItemId String   @unique
  unitCost   Decimal  @default(0) @db.Decimal(14, 2)
  costAmount Decimal  @default(0) @db.Decimal(14, 2)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lineItem QuotationItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)

  @@index([lineItemId])
}

model QuotationPaymentTerm {
  id          String   @id @default(cuid())
  quotationId String
  title       String
  percent     Decimal? @db.Decimal(7, 4)
  amount      Decimal? @db.Decimal(14, 2)
  triggerType String? // e.g. "PROJECT_START", "PROJECT_HANDOVER", "MILESTONE"
  dueDays     Int?    // relative days after triggerType; optional for immediate
  dueDate     DateTime?
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@index([dueDate])
  @@index([sortOrder])
}

model QuotationAcceptance {
  id                String    @id @default(cuid())
  quotationId       String    @unique
  acceptedByName    String?
  acceptedByCompany String?
  acceptedAt        DateTime?
  signatureUrl      String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Proposal {
  id          String   @id @default(cuid())
  quotationId String   @unique
  title       String
  clientName  String
  content     Json
  publicToken String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// -----------------------------
// Settings / Branding (Singleton)
// -----------------------------

model CompanySetting {
  // Singleton row: always upsert by id = "default".
  id                 String   @id @default("default")
  companyName         String   @default("Buildy Pte Ltd")
  legalName           String?  // Optional legal entity name on invoices/contracts
  uen                 String?
  logoUrl             String?
  brandColor          String   @default("#111827")
  accentColor         String   @default("#78716C")
  contactEmail        String   @default("hello@app.buildy.sg")
  contactPhone        String   @default("+65 0000 0000")
  website             String   @default("https://app.buildy.sg")
  registeredAddress   String?
  companyIntro        String   @default("We design and build thoughtfully considered interior spaces, combining refined aesthetics with practical detailing and disciplined project controls.")
  portfolioSummary    String   @default("Residential renovation (HDB, condo, landed) and commercial fit-out delivered with structured scope control, transparent documentation, and long-term aftercare.")
  whyChooseUsText     String?

  gstRegistered       Boolean  @default(true)
  gstRate             Decimal  @default(0.09) @db.Decimal(5, 4)

  defaultPaymentTerms String?
  paymentInstructions String?
  bankName            String?
  bankAccountName     String?
  bankAccountNumber   String?
  paynowUen           String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model NotificationSetting {
  id                 String   @id @default("default")
  emailFromName      String?  @default("Buildy")
  emailFromAddress   String?  // if not set, fallback to env EMAIL_FROM
  whatsappSenderLabel String? // label used in UI templates
  defaultReplyToEmail String?
  defaultSalesPhone   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ProposalThemeSetting {
  id              String   @id @default("default")
  themeName        String   @default("Luxury Editorial")
  coverStyle       String   @default("EDITORIAL_HERO")
  fontStyle        String   @default("SERIF_HEADINGS")
  primaryColor     String   @default("#111827")
  secondaryColor   String   @default("#78716C")
  showCompanyIntro Boolean  @default(true)
  showPortfolio    Boolean  @default(true)
  showWhyChooseUs  Boolean  @default(true)
  showNextSteps    Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// -----------------------------
// Template Library
// -----------------------------

enum TemplateCategory {
  QUOTATION_TERMS
  CONTRACT_CLAUSE
  PROPOSAL_SECTION
  EMAIL
  WHATSAPP
  ROOM
  BOQ_ITEM
  PAYMENT_TERM
  VARIATION_ORDER
}

model TemplateLibraryItem {
  id            String           @id @default(cuid())
  category      TemplateCategory
  code          String
  title         String
  description   String?          @db.Text
  content       String           @db.Text
  variablesJson Json?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([category, code])
  @@index([category])
  @@index([code])
  @@index([isActive])
  @@index([createdAt])
}
