  @@index([type])
  @@index([occurredAt])
  @@index([createdById])
}

model AuditEvent {
  id          String   @id @default(cuid())
  projectId   String?
  actorUserId String?
  module      String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([actorUserId])
  @@index([module])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model EntityRevision {
  id          String   @id @default(cuid())
  projectId   String?
  actorUserId String?
  entityType  String
  entityId    String
  revision    Int
  note        String?
  data        Json
  createdAt   DateTime @default(now())

