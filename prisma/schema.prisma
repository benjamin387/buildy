model Client {
  id            String   @id @default(cuid())
  clientCode    String?  @unique
  name          String
  companyName   String?
  contactPerson String?
  email         String?
  phone         String?
  mobile        String?
  addressLine1  String?
  addressLine2  String?
  postalCode    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contacts  ClientContact[]
  projects   Project[]
  quotations Quotation[]
  portalAccounts ClientPortalAccount[]

  @@index([clientCode])
  @@index([name])
  @@index([companyName])
  @@index([email])
  @@index([phone])
}

model ClientContact {
  id         String   @id @default(cuid())
  clientId   String
  name       String
  email      String?
  phone      String?
  roleTitle  String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  primaryForProjects Project[] @relation("ProjectPrimaryContact")

  @@index([clientId])
  @@index([email])
  @@index([phone])
  @@index([isPrimary])
  @@unique([clientId, email])
}

enum ItemStatus {
  ACTIVE
  INACTIVE
}

model ItemCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  status      ItemStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ItemMaster[]

  @@index([name])
  @@index([status])
}

model UnitOfMeasure {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  symbol    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ItemMaster[]
  quotationItems QuotationItem[]

  @@index([name])
}

model ItemMaster {
  id           String   @id @default(cuid())
  sku          String   @unique
  name         String
  description  String?
  categoryId   String?
  unitId       String?
  sellPrice    Decimal  @default(0) @db.Decimal(14, 2)
  costPrice    Decimal  @default(0) @db.Decimal(14, 2)
  taxCode      String?  // GST-ready coding (e.g. "SR", "ZR", etc)
  status       ItemStatus @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category ItemCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit     UnitOfMeasure? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  quotationItems QuotationItem[]
  invoiceLines InvoiceLine[]
  purchaseOrderLines PurchaseOrderLine[]
  supplierBillLines SupplierBillLine[]
  roomBoqTemplateItems RoomBoqTemplateItem[]
  variationOrderItems VariationOrderItem[]

  @@index([categoryId])
  @@index([unitId])
  @@index([status])
  @@index([name])
}

model Project {
  id            String       @id @default(cuid())
  clientId      String
  primaryClientContactId String?
  projectCode   String?      @unique
  name          String

  clientName    String       @default("")
  clientCompany String?
  clientEmail   String?
  clientPhone   String?

  siteAddress   String       @default("")
  projectType   String       @default("OTHER")
  status        ProjectStatus @default(LEAD)
  quotationStatus QuotationStatus @default(DRAFT)
  contractStatus  ContractStatus  @default(DRAFT)
  billingStatus   BillingStatus   @default(NOT_BILLED)

  startDate            DateTime?
  targetCompletionDate DateTime?
  actualCompletionDate DateTime?

  contractValue        Decimal @default(0) @db.Decimal(14, 2)
  revisedContractValue Decimal @default(0) @db.Decimal(14, 2)
  estimatedCost        Decimal @default(0) @db.Decimal(14, 2)
  committedCost        Decimal @default(0) @db.Decimal(14, 2)
  actualCost           Decimal @default(0) @db.Decimal(14, 2)
  projectedProfit      Decimal @default(0) @db.Decimal(14, 2)
  actualProfit         Decimal @default(0) @db.Decimal(14, 2)

  addressLine1  String
  addressLine2  String?
  postalCode    String?
  propertyType  PropertyType
  unitSizeSqft  Decimal?     @db.Decimal(12, 2)
  contactPerson String?
  contactPhone  String?
  contactEmail  String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  primaryClientContact ClientContact? @relation("ProjectPrimaryContact", fields: [primaryClientContactId], references: [id], onDelete: SetNull)
  quotations Quotation[]
  commercialProfile ProjectCommercialProfile?
  members           ProjectMember[]
  milestones        ProjectMilestone[]
  roleAssignments   ProjectRoleAssignment[]
  tasks             ProjectTask[]
  progressLogs      ProjectProgressLog[]
  timelineItems     ProjectTimelineItem[]
  auditEvents       AuditEvent[]
  revisions         EntityRevision[]
  contracts         Contract[]
  invoices          Invoice[]
  paymentSchedules  PaymentSchedule[]
  receipts          PaymentReceipt[]
  creditNotes       CreditNote[]
  subcontracts      Subcontract[]
  purchaseOrders    PurchaseOrder[]
  supplierBills     SupplierBill[]
  updates           ProjectUpdate[]
  communications    ProjectCommunicationLog[]
  variationOrders   VariationOrder[]
  actualCosts       ActualCostEntry[]
  costLedgers       ProjectCostLedger[]
  profitSnapshots   ProjectProfitSnapshot[]
  pnlAlerts         PnLAlert[]
  collectionCases   CollectionCase[]
  convertedLeads    Lead[]
  siteVisits        SiteVisit[]
  designBriefs      DesignBrief[]
  budgetOptimizationScenarios BudgetOptimizationScenario[]
  upsellRecommendations UpsellRecommendation[]
  outboundMessages  OutboundMessage[]
  publicDocumentLinks PublicDocumentLink[]
  clientPortalAccounts ClientPortalAccount[]
  clientPortalMessages ClientPortalMessage[]
  aiSalesInsights  AISalesInsight[]
  aiSalesMessageDrafts AISalesMessageDraft[]
  cashflowForecastSnapshots CashflowForecastSnapshot[]
  cashflowForecastLines     CashflowForecastLine[]
  documents                 Document[]
  awardedBids               BidOpportunity[] @relation("BidAwardedProject")
  budgets                   ProjectBudget[]
  procurementPlans          ProjectProcurementPlan[]
  progressClaims            ProgressClaim[]
  retentionLedger           RetentionLedger[]
  defectLiabilityPeriod     DefectLiabilityPeriod?
  defectReports             DefectReport[]
  finalAccount              FinalAccount?

  @@index([clientId])
  @@index([primaryClientContactId])
  @@index([propertyType])
  @@index([name])
  @@index([status])
  @@index([projectCode])
}

enum ProjectBudgetSourceType {
  BID_COST_VERSION
  QUOTATION
  MANUAL
}

enum ProjectBudgetStatus {
  DRAFT
  LOCKED
}

model ProjectBudget {
  id              String                 @id @default(cuid())
  projectId        String
  sourceType       ProjectBudgetSourceType @default(MANUAL)

  bidOpportunityId String?
  bidCostVersionId String?
  quotationId      String?
  createdFromBudgetId String?

  versionNo        Int                    @default(1)
  status           ProjectBudgetStatus    @default(DRAFT)
  isActive         Boolean                @default(false)
  lockedAt         DateTime?
  lockedByName     String?
  lockedByEmail    String?
  unlockedAt       DateTime?
  unlockedByName   String?
  unlockedByEmail  String?
  unlockReason     String?
  createdByName    String?
  createdByEmail   String?

  totalCost        Decimal                @default(0) @db.Decimal(14, 2)
  totalRevenue     Decimal                @default(0) @db.Decimal(14, 2)
  notes            String?

  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  project          Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bidOpportunity   BidOpportunity?        @relation("BidOpportunityBudgets", fields: [bidOpportunityId], references: [id], onDelete: SetNull)
  bidCostVersion   BidCostVersion?        @relation("BidCostVersionBudgets", fields: [bidCostVersionId], references: [id], onDelete: SetNull)
  quotation        Quotation?             @relation("QuotationBudgets", fields: [quotationId], references: [id], onDelete: SetNull)
  createdFromBudget ProjectBudget?        @relation("ProjectBudgetRevisions", fields: [createdFromBudgetId], references: [id], onDelete: SetNull)
  revisions         ProjectBudget[]       @relation("ProjectBudgetRevisions")
  lines            ProjectBudgetLine[]
  progressClaims   ProgressClaim[]

  @@unique([projectId, versionNo])
  @@index([projectId])
  @@index([sourceType])
  @@index([status])
  @@index([projectId, isActive])
  @@index([lockedAt])
  @@index([bidOpportunityId])
  @@index([bidCostVersionId])
  @@index([quotationId])
  @@index([createdFromBudgetId])
  @@index([createdAt])
}

model ProjectBudgetLine {
  id              String            @id @default(cuid())
  budgetId         String
  tradeKey         BidTradePackageKey
  description      String
  costAmount       Decimal           @default(0) @db.Decimal(14, 2)
  revenueAmount    Decimal           @default(0) @db.Decimal(14, 2)
  sourceCostVersionLineId String?
  sortOrder        Int               @default(0)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  budget           ProjectBudget     @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  sourceCostVersionLine BidCostVersionLine? @relation("BidCostVersionLineBudgetLines", fields: [sourceCostVersionLineId], references: [id], onDelete: SetNull)
  procurementItems ProjectProcurementPlanItem[] @relation("ProcurementItemSourceBudgetLine")
