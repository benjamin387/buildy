model ProjectTask {
  id              String       @id @default(cuid())
  projectId        String
  milestoneId      String?
  title            String
  description      String?
  assignedTo       String?
  assignedEmail    String?
  roleResponsible  ProjectRole?
  startDate        DateTime?
  dueDate          DateTime?
  completedDate    DateTime?
