model BidOpportunity {
  id              String               @id @default(cuid())
  source          BidOpportunitySource @default(GEBIZ)
  opportunityNo   String               @unique
  title           String
  agency          String
  agencyProfileId String?
  procurementType BidProcurementType   @default(QUOTATION)
  category        String?
  status          BidOpportunityStatus  @default(WATCHING)

  closingDate     DateTime?
  briefingDate    DateTime?
  submittedAt    DateTime?
  awardedAt      DateTime?

  estimatedValue  Decimal?             @db.Decimal(14, 2)
  fitScore        Int                  @default(0)
  fitLabel        BidFitLabel          @default(UNKNOWN)
  importHash      String?              @unique

  bidPrice        Decimal              @default(0) @db.Decimal(14, 2)
  estimatedCost   Decimal              @default(0) @db.Decimal(14, 2)
  targetMargin    Decimal?             @db.Decimal(6, 4)
  finalMargin     Decimal?             @db.Decimal(6, 4)

  strategyMode    BidStrategyMode      @default(BALANCED)
  pricingPosition BidPricingPosition   @default(MATCH)
  strategyNotes   String?

  remarks         String?

  awardedProjectId String?
  awardedContractId String?
  approvedCostVersionId String?
  costingLockedAt DateTime?

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  awardedProject  Project?             @relation("BidAwardedProject", fields: [awardedProjectId], references: [id], onDelete: SetNull)
  awardedContract Contract?            @relation("BidAwardedContract", fields: [awardedContractId], references: [id], onDelete: SetNull)
  approvedCostVersion BidCostVersion?  @relation("BidOpportunityApprovedCostVersion", fields: [approvedCostVersionId], references: [id], onDelete: SetNull)

  documents       BidDocument[]
  costItems       BidCostItem[]
  supplierQuotes  BidSupplierQuote[]
  approvals       BidApproval[]
  activities      BidActivity[]
  submissionChecklist BidSubmissionChecklist[]
  complianceChecklist BidComplianceChecklistItem[]
  timelineMilestones BidTimelineMilestone[]
  winLossRecord  BidWinLossRecord?
  competitorRecords BidCompetitorRecord[]
  rfqs           BidRfq[]
  costVersions   BidCostVersion[]
  gebizImportedItems  GebizImportedItem[] @relation("GebizImportedItemBidOpportunity")
  tenderRequirements TenderDocumentRequirement[]
  generatedTenderDocuments TenderGeneratedDocument[]
  tenderSubmissionPacks TenderSubmissionPack[]
  projectBudgets   ProjectBudget[] @relation("BidOpportunityBudgets")
  procurementPlans ProjectProcurementPlan[] @relation("BidOpportunityProcurementPlans")

  agencyProfile  BidAgencyProfile? @relation(fields: [agencyProfileId], references: [id], onDelete: SetNull)

  @@index([source])
  @@index([status])
  @@index([procurementType])
  @@index([agencyProfileId])
  @@index([closingDate])
  @@index([briefingDate])
  @@index([submittedAt])
  @@index([awardedAt])
  @@index([approvedCostVersionId])
  @@index([costingLockedAt])
  @@index([fitLabel])
  @@index([fitScore])
  @@index([importHash])
  @@index([createdAt])
  @@index([updatedAt])
}

model BidDocument {
  id            String            @id @default(cuid())
  opportunityId String
  documentName  String
  documentType  String?
  fileUrl       String?
  status        BidDocumentStatus @default(REQUIRED)
  dueDate       DateTime?
