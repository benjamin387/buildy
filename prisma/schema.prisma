  contractId         String
  clientPortalAccessId String?
  action             String
  comment            String?
  ipAddress          String?
  userAgent          String?
  createdAt          DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  clientPortalAccess ClientPortalToken? @relation(fields: [clientPortalAccessId], references: [id], onDelete: SetNull)

  @@index([contractId])
  @@index([clientPortalAccessId])
  @@index([action])
  @@index([createdAt])
}

model ClauseTemplate {
  id        String                 @id @default(cuid())
  code      String                 @unique
  title     String
  content   String
  category  ClauseTemplateCategory
  isDefault Boolean                @default(false)
  createdAt DateTime               @default(now())

  @@index([category])
  @@index([isDefault])
  @@index([createdAt])
}

model ContractClause {
  id         String   @id @default(cuid())
  contractId String
  clauseKey  String
  title      String
  content    String
  sortOrder  Int      @default(0)
  isEditable Boolean  @default(true)
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, clauseKey])
  @@index([contractId])
  @@index([sortOrder])
  @@index([clauseKey])
}

model ContractMilestone {
  id          String                 @id @default(cuid())
  contractId  String
  title       String
  description String?
  dueDate     DateTime?
  amount      Decimal                @default(0) @db.Decimal(14, 2)
  status      ContractMilestoneStatus @default(PLANNED)
  sortOrder   Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  progressClaimLines ProgressClaimLine[]

  @@index([contractId])
  @@index([status])
