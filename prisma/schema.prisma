// GeBIZ RSS Auto-Feed
// -------------------

enum GebizImportRunStatus {
  RUNNING
  SUCCESS
  FAILED
}

model GebizFeedSource {
  id                     String   @id @default(cuid())
  name                   String
  rssUrl                 String
  procurementCategoryName String?
  isEnabled              Boolean  @default(true)
  autoImport             Boolean  @default(true)

  defaultOwnerUserId     String?
  minimumEstimatedValue  Decimal? @db.Decimal(14, 2)
  keywordsInclude        String?
  keywordsExclude        String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  defaultOwnerUser User? @relation("GebizFeedSourceDefaultOwner", fields: [defaultOwnerUserId], references: [id], onDelete: SetNull)
  importRuns      GebizImportRun[]
  importedItems   GebizImportedItem[]

  @@index([isEnabled])
  @@index([autoImport])
  @@index([createdAt])
}

model GebizImportRun {
  id           String              @id @default(cuid())
  feedSourceId String
  startedAt    DateTime            @default(now())
  finishedAt   DateTime?
  status       GebizImportRunStatus @default(SUCCESS)
  message      String?
  itemsFetched Int                 @default(0)
  itemsCreated Int                 @default(0)
  itemsSkipped Int                 @default(0)
  errorsJson   Json?

  feedSource GebizFeedSource @relation(fields: [feedSourceId], references: [id], onDelete: Cascade)
  items      GebizImportedItem[]

  @@index([feedSourceId])
  @@index([startedAt])
  @@index([status])
}

model GebizImportedItem {
  id           String   @id @default(cuid())
  feedSourceId String
  importRunId  String?

  opportunityNo String
  title         String
  agency        String?
  publishedAt   DateTime?
  closingDate   DateTime?
  category      String?
  detailUrl     String?
  sourceGuid    String?
  importHash    String?

  estimatedValue Decimal? @db.Decimal(14, 2)
  rawJson        Json?

  bidOpportunityId String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  feedSource    GebizFeedSource @relation(fields: [feedSourceId], references: [id], onDelete: Cascade)
  importRun     GebizImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)
  bidOpportunity BidOpportunity? @relation("GebizImportedItemBidOpportunity", fields: [bidOpportunityId], references: [id], onDelete: SetNull)

  @@unique([feedSourceId, opportunityNo])
  @@unique([feedSourceId, detailUrl])
  @@unique([feedSourceId, importHash])
  @@index([feedSourceId])
  @@index([importRunId])
  @@index([publishedAt])
  @@index([closingDate])
  @@index([createdAt])
}

model GebizOpportunity {
  id                String   @id @default(cuid())
  sourceId          String   @unique
  title             String
  agency            String?
  category          String?
  procurementMethod String?
  publishedAt       DateTime?
  closingAt         DateTime?
  detailUrl         String?  @unique
  status            String   @default("OPEN")
  rawJson           Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([publishedAt])
  @@index([closingAt])
  @@index([status])
  @@index([createdAt])
}

model PermissionRule {
  id        String              @id @default(cuid())
  roleKey   String
  moduleKey PermissionModuleKey

  canView    Boolean @default(false)
  canCreate  Boolean @default(false)
  canEdit    Boolean @default(false)
  canDelete  Boolean @default(false)
  canApprove Boolean @default(false)
  canSend    Boolean @default(false)
  canExport  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleKey, moduleKey])
  @@index([roleKey])
  @@index([moduleKey])
}

model RoleModuleAccess {
  id        String   @id @default(cuid())
  role      String
  moduleKey String
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, moduleKey])
  @@index([role])
  @@index([moduleKey])
}

model Notification {
  id         String               @id @default(cuid())
  userEmail  String
  role       String?
  entityType String
  entityId   String
  title      String
  message    String
  severity   NotificationSeverity @default(INFO)
  channel    NotificationChannel  @default(IN_APP)
  isRead     Boolean              @default(false)
  readAt     DateTime?
  actionUrl  String?
  metadataJson Json?
  createdAt  DateTime             @default(now())

  @@index([userEmail, isRead, createdAt])
  @@index([role, createdAt])
  @@index([severity])
  @@index([channel])
  @@index([entityType, entityId, createdAt])
}

model NotificationPreference {
  id             String   @id @default(cuid())
  userEmail      String   @unique
  enableInApp    Boolean  @default(true)
  enableEmail    Boolean  @default(false)
  enableWhatsApp Boolean  @default(false)
  // Stored as "HH:mm" in Asia/Singapore (e.g. "22:00"). Used only for suppressing
  // non-critical email/WhatsApp dispatch. In-app notifications are not suppressed.
  quietHoursStart String?
  quietHoursEnd   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userEmail])
}

model AuditLog {
  id         String      @id @default(cuid())
  entityType String
  entityId   String
  action     AuditAction
  actorName  String?
  actorEmail String?
  actorRole  String?
  source     AuditSource @default(USER)
  beforeJson Json?
  afterJson  Json?
  metadataJson Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([action])
  @@index([source])
  @@index([actorEmail])
  @@index([createdAt])
}

model ActivityEvent {
  id                 String           @id @default(cuid())
  entityType         String
  entityId           String
  title              String
  description        String?
  severity           ActivitySeverity @default(INFO)
  relatedDocumentType String?
  relatedDocumentId  String?
  createdBy          String?
  metadataJson       Json?
  createdAt          DateTime         @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([severity])
  @@index([createdAt])
}

model Quotation {
  id                   String          @id @default(cuid())
  clientId             String
  projectId            String
  designBriefId        String?
  quotationNumber      String          @map("quoteReferenceNumber")
  version              Int             @default(1)
  isLatest             Boolean         @default(false)
  issueDate            DateTime        @map("quotationDate")
  validityDays         Int?            @default(14)
  status               QuotationStatus @default(DRAFT)

  clientNameSnapshot    String
  companyNameSnapshot   String?
  contactPersonSnapshot String?
  contactPhoneSnapshot  String?
  contactEmailSnapshot  String?

  projectNameSnapshot String
  projectAddress1     String
  projectAddress2     String?
  projectPostalCode   String?
  propertyType        PropertyType
  unitSizeSqft        Decimal?     @db.Decimal(12, 2)

  subtotal       Decimal @default(0) @db.Decimal(14, 2)
  discountAmount Decimal @default(0) @db.Decimal(14, 2)
  estimatedCost  Decimal @default(0) @db.Decimal(14, 2)
  gstAmount      Decimal @default(0) @db.Decimal(14, 2)
  totalAmount    Decimal @default(0) @db.Decimal(14, 2)
  profitAmount   Decimal @default(0) @db.Decimal(14, 2)
  marginPercent  Decimal @default(0) @db.Decimal(7, 4)

  paymentTerms  String?
  exclusions    String?
  notes         String?
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project    Project              @relation(fields: [projectId], references: [id], onDelete: Restrict)
  designBrief DesignBrief?        @relation(fields: [designBriefId], references: [id], onDelete: SetNull)
  sections   QuotationSection[]
  acceptance QuotationAcceptance?
  contracts  Contract[]
  variationOrders VariationOrder[]
  invoices   Invoice[]
  paymentSchedules PaymentSchedule[]
  paymentTermsV2 QuotationPaymentTerm[]
  budgets   ProjectBudget[] @relation("QuotationBudgets")
  followUps ClientFollowUp[]
  proposal  Proposal?

  @@unique([quotationNumber, version])
  @@index([clientId])
  @@index([projectId])
  @@index([designBriefId])
  @@index([projectId, isLatest])
  @@index([issueDate])
  @@index([status])
}

model Contract {
  id             String         @id @default(cuid())
  projectId      String
  quotationId    String?
  contractNumber String
  version        Int            @default(1)
  contractDate   DateTime
  status         ContractStatus @default(DRAFT)
  signedAt       DateTime?

  clientNameSnapshot  String
  clientCompanySnapshot String?
  clientEmailSnapshot String?
  clientPhoneSnapshot String?
  projectNameSnapshot String
  projectAddress1     String
  projectAddress2     String?
  projectPostalCode   String?

  contractSubtotal Decimal @default(0) @db.Decimal(14, 2)
  discountAmount   Decimal @default(0) @db.Decimal(14, 2)
  gstAmount        Decimal @default(0) @db.Decimal(14, 2)
  totalAmount      Decimal @default(0) @db.Decimal(14, 2)
  contractValue    Decimal @default(0) @db.Decimal(14, 2)
  retentionAmount  Decimal @default(0) @db.Decimal(14, 2)
  // Optional: preferred retention percentage (e.g. 0.05 for 5%). If set,
  // retentionAmount acts as a cap when > 0.
  retentionPercent Decimal @default(0) @db.Decimal(7, 4)
  defectsLiabilityDays Int @default(0)
  warrantyMonths   Int    @default(0)

  startDate      DateTime?
  completionDate DateTime?

  scopeOfWork String?
  paymentTerms String?
  warrantyTerms String?
  variationPolicy String?
  defectsPolicy String?
  insurancePolicy String?
  termsText String?
  notes String?

  scopeSnapshot Json?
  paymentTermsSnapshot Json?
  lockedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quotation Quotation?  @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  variationOrders VariationOrder[]
  invoices  Invoice[]
  paymentSchedules PaymentSchedule[]
  milestones ContractMilestone[]
  clauses   ContractClause[]

  signatureRequests SignatureRequest[]
  contractSignatures ContractSignature[]
  contractApprovalLogs ContractApprovalLog[]
  awardedBids       BidOpportunity[] @relation("BidAwardedContract")
  progressClaims    ProgressClaim[]
  retentionLedger   RetentionLedger[]
  defectLiabilityPeriods DefectLiabilityPeriod[]
  finalAccounts     FinalAccount[]

  @@unique([contractNumber, version])
  @@index([projectId])
  @@index([quotationId])
  @@index([contractDate])
  @@index([signedAt])
  @@index([status])

  @@map("JobContract")
}

model ContractSignature {
  id                 String   @id @default(cuid())
  contractId         String
  clientPortalAccessId String
  signerName         String
  signerEmail        String
  signerPhone        String?
  signatureDataUrl   String
  signedIpAddress    String?
  signedUserAgent    String?
  signedAt           DateTime?
  status             String   @default("PENDING")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  clientPortalAccess ClientPortalToken @relation(fields: [clientPortalAccessId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([clientPortalAccessId])
  @@index([status])
  @@index([signedAt])
  @@index([createdAt])
  @@unique([contractId, clientPortalAccessId])
}

model ContractApprovalLog {
